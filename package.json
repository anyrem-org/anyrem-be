{
  "name": "anyrem-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "nest start --watch --tsc --entryFile main.js",
    "dev:worker": "nest start --watch --tsc --entryFile worker.js",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "avatars:import": "tsx scripts/import-avatars.ts",
    "search:reindex": "tsx scripts/reindex-search.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/swagger": "11.4.4",
    "@prisma/client": "^6.19.1",
    "argon2": "^0.44.0",
    "bullmq": "^5.66.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.8.2",
    "meilisearch": "^0.54.0",
    "nodemailer": "^7.0.10",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@types/express": "^5.0.5",
    "@types/node": "^22.19.1",
    "@types/nodemailer": "^7.0.4",
    "prisma": "^6.19.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
