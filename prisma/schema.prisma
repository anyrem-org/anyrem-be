generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}
enum AuthProvider {
  EMAIL
  GOOGLE
}
enum AuthTokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
}
enum NoteRelationType {
  MANUAL
  SIMILAR
}
enum ActivityType {
  CREATED
  VIEWED
  EDITED
  PINNED
  UNPINNED
}
enum NotificationProvider {
  EMAIL
  TELEGRAM
}
enum DeliveryStatus {
  PENDING
  SENT
  FAILED
}

model AvatarCatalog {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  provider  String   @db.VarChar(40)
  version   String   @db.VarChar(40)
  style     String   @db.VarChar(60)
  styleName String   @map("style_name") @db.VarChar(100)
  seed      String   @db.VarChar(120)
  filePath  String   @map("file_path") @db.VarChar(255)
  sortOrder Int      @map("sort_order") @default(0)
  isActive  Boolean  @map("is_active") @default(true)
  createdAt DateTime @map("created_at") @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @map("updated_at") @updatedAt @db.Timestamptz(3)
  users     User[]
  @@unique([provider, version, style, seed])
  @@index([style])
  @@index([isActive])
  @@index([sortOrder])
  @@map("avatars")
}

model User {
  id              String       @id @default(uuid()) @db.Uuid
  email           String       @unique @db.Citext
  emailVerifiedAt DateTime?    @db.Timestamptz(3)
  name            String       @db.VarChar(120)
  avatarId        String?      @db.Uuid
  avatar          AvatarCatalog? @relation(fields: [avatarId], references: [id], onDelete: SetNull)
  status          UserStatus   @default(ACTIVE)
  createdAt       DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime     @updatedAt @db.Timestamptz(3)
  deletedAt       DateTime?    @db.Timestamptz(3)
  accounts        AuthAccount[]
  authTokens      AuthToken[]
  sessions        RefreshSession[]
  settings        UserSetting[]
  notes           Note[]
  categories      Category[]
  relations       NoteRelation[]
  activities      ActivityEvent[]
  histories       SearchHistory[]
  summaries       DailySummary[]
  deliveries      NotificationDelivery[]
  @@map("users")
}

model AuthAccount {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @db.Uuid
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          AuthProvider
  providerAccountId String       @db.VarChar(255)
  passwordHash      String?
  createdAt         DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime     @updatedAt @db.Timestamptz(3)
  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@map("auth_accounts")
}

model AuthToken {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @db.Uuid
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AuthTokenType
  tokenHash String        @unique @db.Char(64)
  expiresAt DateTime      @db.Timestamptz(3)
  usedAt    DateTime?     @db.Timestamptz(3)
  createdAt DateTime      @default(now()) @db.Timestamptz(3)
  @@index([userId, type])
  @@map("auth_tokens")
}

model RefreshSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @unique @db.Char(64)
  deviceName       String?   @db.VarChar(120)
  expiresAt        DateTime  @db.Timestamptz(3)
  revokedAt        DateTime? @db.Timestamptz(3)
  lastUsedAt       DateTime  @default(now()) @db.Timestamptz(3)
  createdAt        DateTime  @default(now()) @db.Timestamptz(3)
  @@index([userId, revokedAt])
  @@map("refresh_sessions")
}

model UserSetting {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @db.VarChar(40)
  key       String   @db.VarChar(80)
  value     Json
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  @@unique([userId, type, key])
  @@index([userId, type])
  @@index([type, key, userId])
  @@map("user_settings")
}

model Note {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String    @db.VarChar(300)
  contentJson    Json
  contentText    String
  contentHtml    String?
  pinned         Boolean   @default(false)
  lastOpenedAt   DateTime? @db.Timestamptz(3)
  archivedAt     DateTime? @db.Timestamptz(3)
  deletedAt      DateTime? @db.Timestamptz(3)
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(3)
  categories     NoteCategory[]
  relationsLeft  NoteRelation[] @relation("RelationLeft")
  relationsRight NoteRelation[] @relation("RelationRight")
  activities     ActivityEvent[]
  @@unique([id, userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, lastOpenedAt(sort: Desc)])
  @@map("notes")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   @db.Citext
  description String?  @db.VarChar(500)
  color       String   @db.Char(7)
  icon        String?  @db.VarChar(40)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)
  notes       NoteCategory[]
  @@unique([id, userId])
  @@unique([userId, name])
  @@map("categories")
}

model NoteCategory {
  userId     String   @db.Uuid
  noteId     String   @db.Uuid
  categoryId String   @db.Uuid
  note       Note     @relation(fields: [noteId, userId], references: [id, userId], onDelete: Cascade)
  category   Category @relation(fields: [categoryId, userId], references: [id, userId], onDelete: Restrict)
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  @@id([noteId, categoryId])
  @@index([categoryId, noteId])
  @@map("note_categories")
}

model NoteRelation {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @db.Uuid
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  leftNoteId  String           @db.Uuid
  rightNoteId String           @db.Uuid
  leftNote    Note             @relation("RelationLeft", fields: [leftNoteId, userId], references: [id, userId], onDelete: Cascade)
  rightNote   Note             @relation("RelationRight", fields: [rightNoteId, userId], references: [id, userId], onDelete: Cascade)
  type        NoteRelationType @default(MANUAL)
  score       Float?
  reason      String?          @db.VarChar(255)
  createdAt   DateTime         @default(now()) @db.Timestamptz(3)
  @@unique([leftNoteId, rightNoteId, type])
  @@index([userId, leftNoteId])
  @@index([userId, rightNoteId])
  @@map("note_relations")
}

model ActivityEvent {
  id         BigInt       @id @default(autoincrement())
  userId     String       @db.Uuid
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteId     String       @db.Uuid
  note       Note         @relation(fields: [noteId, userId], references: [id, userId], onDelete: Cascade)
  type       ActivityType
  occurredAt DateTime     @default(now()) @db.Timestamptz(3)
  @@index([userId, occurredAt(sort: Desc)])
  @@index([userId, noteId, occurredAt(sort: Desc)])
  @@map("activity_events")
}

model SearchHistory {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyword           String   @db.VarChar(300)
  keywordNormalized String   @db.VarChar(300)
  searchCount       Int      @default(1)
  lastSearchedAt    DateTime @default(now()) @db.Timestamptz(3)
  @@unique([userId, keywordNormalized])
  @@index([userId, lastSearchedAt(sort: Desc)])
  @@map("search_histories")
}

model DailySummary {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  localDate    DateTime @db.Date
  timezone     String   @db.VarChar(64)
  contentJson  Json
  contentText  String
  noteCount    Int
  generatedAt  DateTime @default(now()) @db.Timestamptz(3)
  deliveries   NotificationDelivery[]
  @@unique([userId, localDate])
  @@index([userId, localDate(sort: Desc)])
  @@map("daily_summaries")
}

model NotificationDelivery {
  id             BigInt               @id @default(autoincrement())
  dailySummaryId String               @db.Uuid
  summary        DailySummary         @relation(fields: [dailySummaryId], references: [id], onDelete: Cascade)
  userId         String               @db.Uuid
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       NotificationProvider
  recipientMasked String              @db.VarChar(255)
  status         DeliveryStatus       @default(PENDING)
  attemptCount   Int                  @default(0)
  errorMessage   String?
  sentAt         DateTime?            @db.Timestamptz(3)
  createdAt      DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime             @updatedAt @db.Timestamptz(3)
  @@unique([dailySummaryId, provider])
  @@index([status, updatedAt])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notification_deliveries")
}
